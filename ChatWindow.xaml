<Window x:Class="MutsumiPet.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mutsumi Input"
        Width="540"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="CompletionBorder"
                Margin="0,0,0,10"
                Padding="10,8"
                Background="#F7F7F7"
                BorderBrush="#16000000"
                BorderThickness="1"
                CornerRadius="16"
                Visibility="Collapsed">
            <ListBox x:Name="CompletionListBox"
                     BorderThickness="0"
                     Background="Transparent"
                     MaxHeight="210"
                     SelectionMode="Single"
                     PreviewMouseLeftButtonUp="CompletionListBox_PreviewMouseLeftButtonUp">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CommandText}"
                                       FontFamily="Microsoft YaHei UI"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#202124" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Description}"
                                       FontFamily="Microsoft YaHei UI"
                                       FontSize="15"
                                       Foreground="#8A8D91"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="1"
                Margin="0,0,0,0"
                Padding="18,14"
                Background="#FBFBFB"
                BorderBrush="#16000000"
                BorderThickness="1"
                CornerRadius="22"
                VerticalAlignment="Bottom">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="InputTextBox"
                         MinHeight="42"
                         MaxHeight="96"
                         Padding="0"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Microsoft YaHei UI"
                         FontSize="18"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="InputTextBox_TextChanged"
                         PreviewKeyDown="InputTextBox_PreviewKeyDown" />

                <Grid Grid.Row="1"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="和小睦说点什么吧"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="13"
                               Foreground="#8A8D91"
                               VerticalAlignment="Center" />

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Width="34"
                            Height="34"
                            HorizontalAlignment="Right"
                            Padding="0"
                            Background="#1F2328"
                            Foreground="White"
                            BorderThickness="0"
                            Click="SendButton_Click">
                        <TextBlock Text="↑"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
