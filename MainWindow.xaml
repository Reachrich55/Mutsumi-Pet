<Window x:Class="MutsumiPet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mutsumi Pet"
        Width="420"
        Height="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="刷新对话" Click="RefreshMenuItem_Click" />
            <MenuItem x:Name="PauseMenuItem" Header="暂停互动" IsCheckable="True" Click="PauseMenuItem_Click" />
            <Separator />
            <MenuItem Header="退出" Click="ExitMenuItem_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Viewbox Stretch="Fill">
        <Canvas Width="600" Height="600">
            <Image x:Name="PetImage"
                   Width="600"
                   Height="600"
                   Stretch="Fill"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Border Canvas.Left="58"
                    Canvas.Top="80"
                    Width="238"
                    Height="124"
                    Padding="10,8"
                    Background="Transparent"
                    ClipToBounds="True">
                <Grid>
                    <TextBlock x:Name="SpeechText"
                               Text="我在这里。"
                               FontFamily="Microsoft YaHei UI"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="#0B3418"
                               LineHeight="27"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               MaxWidth="214" />
                </Grid>
            </Border>
        </Canvas>
    </Viewbox>
</Window>
